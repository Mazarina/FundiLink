{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "SET_VIA_USER_SECRETS_OR_ENV"
  },
  "JwtSettings": {
    "SecretKey": "SET_VIA_USER_SECRETS_OR_ENV",
    "Issuer": "FundiLink",
    "Audience": "FundiLink",
    "ExpiryMinutes": "60"
  },
  "DocumentStorage": {
    "RootPath": "document-store",
    "MaxSizeBytes": 10485760
  }
}
