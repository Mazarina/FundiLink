*.scc
ipch/
*.aps
*.pch
*.wsuo
*.ncb
*.pdb
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.ipch

## ── VS Code ──────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.code-workspace
.history/

## ── JetBrains Rider ──────────────────────────────────────────
.idea/
*.sln.iml
*.iws
out/
.idea_modules/

## ── Node / npm / yarn / pnpm ─────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
package-lock.json
yarn.lock
pnpm-lock.yaml

## ── Vite / React Build Output ───────────────────────────────
dist/
dist-ssr/
build/
.vite/
*.local

## ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo

## ── Storybook ────────────────────────────────────────────────
storybook-static/

## ── Testing ──────────────────────────────────────────────────
coverage/
.nyc_output/
cypress/screenshots/
cypress/videos/
playwright-report/
test-results/

## ── Docker ───────────────────────────────────────────────────
# Keep docker-compose.yml but ignore local override files
docker-compose.override.yml
docker-compose.local.yml
.docker/

## ── Database ─────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
*.mdf
*.ldf
*.bak
pgdata/
postgres-data/

## ── Logs ─────────────────────────────────────────────────────
*.log
logs/
log/
*.log.*

## ── macOS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

## ── Windows ──────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

## ── Linux ────────────────────────────────────────────────────
*~
.nfs*

## ── Uploads / User Files (never commit user documents) ───────
uploads/
local-uploads/
document-storage/
wwwroot/uploads/

## ── Temporary Files ──────────────────────────────────────────
*.tmp
*.temp
*.swp
*.bak
*.orig
*.cache

## ── Claude Code ──────────────────────────────────────────────
.claude/
document-store/
