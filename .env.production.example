# Copy this file to /opt/fundilink/env/.env on the VPS and fill in real values.
# NEVER commit a filled-in copy of this file.

# --- Database ---
POSTGRES_DB=fundilink_prod
POSTGRES_USER=fundilink_prod
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# --- JWT ---
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_ISSUER=FundiLink
JWT_AUDIENCE=FundiLink
JWT_EXPIRY_MINUTES=60

# --- CORS / URLs ---
# Comma-separated list of allowed origins. Production should allow only the
# FundiLink frontend.
CORS_ALLOWED_ORIGINS=https://fundilink.zultek.co.za
FRONTEND_URL=https://fundilink.zultek.co.za
API_BASE_URL=https://api-fundilink.zultek.co.za

# Built into the frontend at image-build time.
VITE_API_BASE_URL=https://api-fundilink.zultek.co.za

# --- Document storage ---
UPLOADS_PATH=/opt/fundilink/uploads
DOCUMENT_MAX_SIZE_BYTES=10485760

# --- Rate limiting ---
RATE_LIMIT_PERMIT_LIMIT=100
RATE_LIMIT_WINDOW_SECONDS=60
