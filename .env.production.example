# Copy this file to /opt/fundilink/env/fundilink.env on the VPS and fill in real values.
# NEVER commit a filled-in copy of this file.

# --- Database ---
POSTGRES_DB=fundilink_prod
POSTGRES_USER=fundilink_prod
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# --- JWT ---
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_ISSUER=FundiLink
JWT_AUDIENCE=FundiLink
JWT_EXPIRY_MINUTES=60

# --- CORS / URLs ---
CORS_ALLOWED_ORIGINS=https://fundilink.zultek.co.za
FRONTEND_URL=https://fundilink.zultek.co.za
API_BASE_URL=https://api.fundilink.zultek.co.za

# Built into the frontend Docker image at build time.
VITE_API_BASE_URL=https://api.fundilink.zultek.co.za

# --- Document storage ---
# This path is bind-mounted into the API container. Created by the deploy workflow.
# UPLOADS_PATH is no longer used in docker-compose.production.yml (path is hardcoded
# to /opt/fundilink/storage/documents for security — do not change without updating
# docker-compose.production.yml as well).
DOCUMENT_MAX_SIZE_BYTES=10485760

# --- Rate limiting ---
RATE_LIMIT_PERMIT_LIMIT=100
RATE_LIMIT_WINDOW_SECONDS=60

# --- ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Production
